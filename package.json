{
  "name": "@romaco/mcp",
  "version": "0.0.3",
  "description": "MCP server for romaco-charts — control your trading chart from Claude, Cursor, or any MCP-compatible AI agent",
  "type": "module",
  "bin": {
    "romaco-mcp": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench --run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.20.1",
    "yahoo-finance2": "^3.14.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "romaco-charts": ">=1.0.0-beta.6"
  },
  "peerDependenciesMeta": {
    "romaco-charts": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "romaco",
    "trading",
    "charts",
    "ai",
    "claude",
    "cursor",
    "model-context-protocol"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/romaco-labs/romaco-mcp"
  },
  "homepage": "https://github.com/romaco-labs/romaco-mcp#readme",
  "bugs": {
    "url": "https://github.com/romaco-labs/romaco-mcp/issues"
  }
}
