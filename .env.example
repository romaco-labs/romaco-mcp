# ── romaco MCP — config ──────────────────────────────────────────────────────

# WebSocket bridge port (live chart). Default 7399.
# ROMACO_MCP_PORT=7399

# OHLCV candle cache directory. Default ~/.romaco/cache
# ROMACO_CACHE_DIR=

# ── ROA-I (Pro) ──────────────────────────────────────────────────────────────
# FREE: leave ROMACO_TOKEN empty → local analysis with yfinance/raw, bounded by
#       whatever model your agent uses.
# PRO:  set your romaco.tech API key → analysis tools forward the heavy compute
#       to the ROA-I backend (falls back to local if unreachable).
ROMACO_TOKEN=

# ROA-I backend. Dev: localhost. Prod: https://api.romaco.tech
ROMACO_API_URL=http://localhost:8000

# ── Auto-open browser ─────────────────────────────────────────────────────────
# When set, romaco_setup_chart opens this URL automatically if no McpBridge is
# connected yet — gives you the chart tab without leaving the terminal.
# Local dev: ROMACO_APP_URL=http://localhost:5173
# Hosted:    ROMACO_APP_URL=https://romaco.tech/dashboard
# ROMACO_APP_URL=
